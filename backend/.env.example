# 이 파일을 복사해서 .env 로 저장 후 값을 채워넣으세요
# cp .env.example .env

# ── 데이터베이스 ──────────────────────────────────────────
# SQLite (기본값, 로컬 개발용)
DATABASE_URL=sqlite+aiosqlite:///./kanban.db

# PostgreSQL 사용 시 아래로 교체 (Railway에서는 자동으로 주입됨)
# DATABASE_URL=postgresql://user:password@host:5432/kanban

# ── 세션 보안 ──────────────────────────────────────────────
# 랜덤한 긴 문자열로 교체할 것 (예: openssl rand -hex 32)
SECRET_KEY=dev-secret-key-change-in-production

# ── CORS (배포 시 프론트엔드 URL 입력) ───────────────────────
FRONTEND_URL=https://your-frontend.up.railway.app

# ── Google OAuth ───────────────────────────────────────────
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보에서 발급
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend.up.railway.app/auth/google/callback

# ── GCS-PULSE (1000school 회의실 API) ────────────────────────
GCS_PULSE_TOKEN=your-gcs-pulse-api-token
GCS_PULSE_BASE_URL=https://api.1000.school
